# OpenAI-compatible local completion server.
# Matches request_test.sh by default.
QA_WIKI_BASE_URL=http://localhost:8000/v1
QA_WIKI_MODEL=leon-se/gemma-4-E4B-it-FP8-Dynamic
QA_WIKI_API_KEY=local

# Generation defaults for JSON extraction.
QA_WIKI_TEMPERATURE=0.1
QA_WIKI_MAX_TOKENS=2048
QA_WIKI_TIMEOUT=120
QA_WIKI_MAX_RETRIES=1

# Max in-flight LLM requests per batch loop. 1 = sequential (no concurrency).
QA_WIKI_MAX_CONCURRENCY=1
