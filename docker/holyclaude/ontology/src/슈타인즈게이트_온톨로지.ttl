@prefix sg: <http://example.org/steinsgate#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix swrl: <http://www.w3.org/2003/11/swrl#> .
@prefix swrla: <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix sgsh: <http://example.org/steinsgate/shapes#> .

sg:OntologyConcept3 a owl:Ontology ;
    rdfs:label "슈타인즈 게이트 사건 온톨로지 v3"@ko ;
    rdfs:comment """
사건 질의 응답용 단순화 버전.

설계 원칙:
- Character 노드는 두지 않는다.
- 기억, 성격, 믿음, 관측 전용 모델은 제거한다.
- 사건의 식별은 EventVariation/Event ID로 하고, 시간은 정렬 좌표로만 사용한다.
- WorldLine은 다이버전스 미터에 표시되는 소수점 이하 6자리 좌표를 기준으로 식별한다.
- 같은 6자리 divergence 아래에서도 더 미세한 차이가 남을 수 있으므로, 작품이 구분하는 시나리오 차이는 EventVariation으로 표현한다.
- 과학 레이어의 sub-display 세계선 이동은 hidden WorldLine/WorldLineShift로 만들지 않고 ScienceTopic과 EvidenceSource로 설명한다.
- 동일한 로컬 시각에 여러 세계선/변형의 사건이 동시에 존재할 수 있다.
- 타임리프 반복은 별도 iteration 클래스로 모델링하지 않고, 작품에서 구분 가능한 시나리오만 EventVariation으로 남긴다.
"""@ko .


### =============================================
### Core Classes
### =============================================

sg:AttractorField a owl:Class ;
    rdfs:label "어트랙터 필드"@ko ;
    rdfs:comment "여러 세계선에 걸친 거시적 수속 결과 패턴의 묶음."@ko .

sg:WorldLine a owl:Class ;
    rdfs:label "세계선"@ko ;
    rdfs:comment "다이버전스 미터에 표시되는 소수점 이하 6자리 좌표를 기준으로 식별한 관측 가능한 세계선 단위."@ko .

sg:MacroEvent a owl:Class ;
    rdfs:label "거시 사건"@ko ;
    rdfs:comment "특정 테마나 기간을 가진 큰 서사 구간."@ko .

sg:EventVariation a owl:Class ;
    rdfs:label "사건 변형"@ko ;
    rdfs:comment "같은 거시 사건 안에서 작품이 구분하는 시나리오 단위. 동일한 6자리 divergence 아래의 하위 분기도 여기서 분리한다."@ko .

sg:Event a owl:Class ;
    rdfs:label "사건"@ko ;
    rdfs:comment """질의 가능한 원자 사건.

eventType 값:
  actual / intervention / communication / travel / death

mechanismType 값:
  dmail / timeleap / physicaltravel / videodmail / none
"""@ko .

sg:ConvergencePattern a owl:Class ;
    rdfs:label "수속 패턴"@ko ;
    rdfs:comment "여러 세계선에서 반복되는 공통 결과 패턴."@ko .

sg:WorldLineShift a owl:Class ;
    rdfs:label "세계선 이동"@ko ;
    rdfs:comment "활성 세계선 전환 기록."@ko .

sg:MediaSource a owl:Class ;
    rdfs:label "미디어 소스"@ko ;
    rdfs:comment "사건이 등장하는 특정 미디어의 최소 단위(화, 챕터, 권)."@ko .

sg:ScienceTopic a owl:Class ;
    rdfs:label "과학 해설 주제"@ko ;
    rdfs:comment "세계선 과학 원리와 답변 라벨을 기존 온톨로지 인스턴스에 연결하는 해설 노드."@ko .

sg:EvidenceSource a owl:Class ;
    rdfs:label "근거 소스"@ko ;
    rdfs:comment "과학 해설 주제를 뒷받침하는 구조화 데이터, 공식자료, 제작진 인터뷰, 보조 자료 출처."@ko .


### =============================================
### Object Properties
### =============================================

sg:hasVariation a owl:ObjectProperty ;
    rdfs:domain sg:MacroEvent ;
    rdfs:range sg:EventVariation ;
    rdfs:label "변형을 가진다"@ko .

sg:partOfMacroEvent a owl:ObjectProperty ;
    rdfs:domain sg:EventVariation ;
    rdfs:range sg:MacroEvent ;
    owl:inverseOf sg:hasVariation ;
    rdfs:label "거시 사건에 속한다"@ko .

sg:hasEvent a owl:ObjectProperty ;
    rdfs:domain sg:EventVariation ;
    rdfs:range sg:Event ;
    rdfs:label "사건을 가진다"@ko .

sg:partOfVariation a owl:ObjectProperty ;
    rdfs:domain sg:Event ;
    rdfs:range sg:EventVariation ;
    owl:inverseOf sg:hasEvent ;
    rdfs:label "사건 변형에 속한다"@ko .

sg:hasWorldLine a owl:ObjectProperty ;
    rdfs:domain sg:AttractorField ;
    rdfs:range sg:WorldLine ;
    rdfs:label "세계선을 가진다"@ko .

sg:belongsToAttractorField a owl:ObjectProperty ;
    rdfs:domain sg:WorldLine ;
    rdfs:range sg:AttractorField ;
    owl:inverseOf sg:hasWorldLine ;
    rdfs:label "어트랙터 필드에 속한다"@ko .

sg:belongsToWorldLine a owl:ObjectProperty ;
    rdfs:domain sg:EventVariation ;
    rdfs:range sg:WorldLine ;
    rdfs:label "세계선에 속한다"@ko .

sg:hasConvergencePattern a owl:ObjectProperty ;
    rdfs:domain sg:AttractorField ;
    rdfs:range sg:ConvergencePattern ;
    rdfs:label "수속 패턴을 가진다"@ko .

sg:hasVariantVariation a owl:ObjectProperty ;
    rdfs:domain sg:ConvergencePattern ;
    rdfs:range sg:EventVariation ;
    rdfs:label "변형 시나리오를 가진다"@ko .

sg:causes a owl:ObjectProperty ;
    rdfs:domain sg:Event ;
    rdfs:range sg:Event ;
    rdfs:label "원인이 된다"@ko .

sg:enables a owl:ObjectProperty ;
    rdfs:domain sg:Event ;
    rdfs:range sg:Event ;
    rdfs:label "가능하게 한다"@ko .

sg:prevents a owl:ObjectProperty ;
    rdfs:domain sg:Event ;
    rdfs:range sg:Event ;
    rdfs:label "방지한다"@ko .

sg:fromWorldLine a owl:ObjectProperty ;
    rdfs:domain sg:WorldLineShift ;
    rdfs:range sg:WorldLine ;
    rdfs:label "이전 세계선"@ko .

sg:toWorldLine a owl:ObjectProperty ;
    rdfs:domain sg:WorldLineShift ;
    rdfs:range sg:WorldLine ;
    rdfs:label "이동 후 세계선"@ko .

sg:triggeredByEvent a owl:ObjectProperty ;
    rdfs:domain sg:WorldLineShift ;
    rdfs:range sg:Event ;
    rdfs:label "유발 사건"@ko .

sg:participatesInShift a owl:ObjectProperty ;
    rdfs:domain sg:Event ;
    rdfs:range sg:WorldLineShift ;
    rdfs:label "세계선 이동에 관여한다"@ko .

sg:appearsIn a owl:ObjectProperty ;
    rdfs:domain sg:Event ;
    rdfs:range sg:MediaSource ;
    rdfs:label "등장 미디어"@ko ;
    rdfs:comment "해당 사건이 묘사되는 미디어 소스(화/챕터 수준)."@ko .

sg:explainsEntity a owl:ObjectProperty ;
    rdfs:domain sg:ScienceTopic ;
    rdfs:range rdfs:Resource ;
    rdfs:label "해설 대상"@ko ;
    rdfs:comment "과학 해설 주제가 설명하는 기존 온톨로지 인스턴스."@ko .

sg:supportedByEvidence a owl:ObjectProperty ;
    rdfs:domain sg:ScienceTopic ;
    rdfs:range sg:EvidenceSource ;
    rdfs:label "근거로 지지됨"@ko .

sg:relatedTopic a owl:ObjectProperty ;
    rdfs:domain sg:ScienceTopic ;
    rdfs:range sg:ScienceTopic ;
    rdfs:label "관련 해설 주제"@ko .


### =============================================
### Datatype Properties
### =============================================

sg:id a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "식별자"@ko .

sg:nameEn a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "영문 이름"@ko .

sg:labelKo a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "한글 라벨"@ko .

sg:description a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "설명"@ko .

sg:summary a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "요약"@ko .

sg:note a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "세부 노트"@ko ;
    rdfs:comment "반복 회차, 불확실한 세부, 질의 응답용 맥락을 서술한다."@ko .

sg:variationIdentity a owl:DatatypeProperty ;
    rdfs:domain sg:EventVariation ;
    rdfs:range xsd:string ;
    rdfs:label "변형 식별자"@ko .

sg:branchCondition a owl:DatatypeProperty ;
    rdfs:domain sg:EventVariation ;
    rdfs:range xsd:string ;
    rdfs:label "분기 조건"@ko .

sg:divergenceValue a owl:DatatypeProperty ;
    rdfs:domain sg:WorldLine ;
    rdfs:range xsd:decimal ;
    rdfs:label "다이버전스 수치"@ko .

sg:isActive a owl:DatatypeProperty ;
    rdfs:domain sg:WorldLine ;
    rdfs:range xsd:boolean ;
    rdfs:label "현재 활성 여부"@ko .

sg:localDateTime a owl:DatatypeProperty ;
    rdfs:domain sg:Event ;
    rdfs:range xsd:string ;
    rdfs:label "세계선 로컬 시각"@ko ;
    rdfs:comment "형식: YYYY-MM-DD HH:MM. 사건 식별자가 아니라 정렬용 좌표."@ko .

sg:timePrecision a owl:DatatypeProperty ;
    rdfs:domain sg:Event ;
    rdfs:range xsd:string ;
    rdfs:label "시간 정밀도"@ko ;
    rdfs:comment "exact / approximate / day / unknown"@ko .


sg:eventType a owl:DatatypeProperty ;
    rdfs:domain sg:Event ;
    rdfs:range xsd:string ;
    rdfs:label "사건 유형"@ko .

sg:mechanismType a owl:DatatypeProperty ;
    rdfs:domain sg:Event ;
    rdfs:range xsd:string ;
    rdfs:label "메커니즘 유형"@ko .

sg:place a owl:DatatypeProperty ;
    rdfs:domain sg:Event ;
    rdfs:range xsd:string ;
    rdfs:label "발생 장소"@ko .

sg:actor a owl:DatatypeProperty ;
    rdfs:domain sg:Event ;
    rdfs:range xsd:string ;
    rdfs:label "행위자"@ko .

sg:target a owl:DatatypeProperty ;
    rdfs:domain sg:Event ;
    rdfs:range xsd:string ;
    rdfs:label "대상"@ko .

sg:timeWindow a owl:DatatypeProperty ;
    rdfs:domain sg:ConvergencePattern ;
    rdfs:range xsd:string ;
    rdfs:label "시간 창"@ko .

sg:appliesToCharacter a owl:DatatypeProperty ;
    rdfs:domain sg:ConvergencePattern ;
    rdfs:range xsd:string ;
    rdfs:label "대상 인물 식별 문자열"@ko .

sg:shiftMoment a owl:DatatypeProperty ;
    rdfs:domain sg:WorldLineShift ;
    rdfs:range xsd:string ;
    rdfs:label "이동 발생 시각"@ko .

sg:shiftType a owl:DatatypeProperty ;
    rdfs:domain sg:WorldLineShift ;
    rdfs:range xsd:string ;
    rdfs:label "이동 유형"@ko .

sg:mediaType a owl:DatatypeProperty ;
    rdfs:domain sg:MediaSource ;
    rdfs:range xsd:string ;
    rdfs:label "미디어 유형"@ko ;
    rdfs:comment "anime / game / novel"@ko .

sg:mediaTitle a owl:DatatypeProperty ;
    rdfs:domain sg:MediaSource ;
    rdfs:range xsd:string ;
    rdfs:label "작품명"@ko ;
    rdfs:comment "Steins;Gate / Steins;Gate 0 / Steins;Gate Elite 등"@ko .

sg:mediaUnit a owl:DatatypeProperty ;
    rdfs:domain sg:MediaSource ;
    rdfs:range xsd:string ;
    rdfs:label "화/챕터/권"@ko ;
    rdfs:comment "애니 → '1화', 게임 → 'Chapter 3', 소설 → '상권'"@ko .

sg:evidenceTier a owl:DatatypeProperty ;
    rdfs:domain sg:EvidenceSource ;
    rdfs:range xsd:string ;
    rdfs:label "근거 계층"@ko .

sg:sourcePath a owl:DatatypeProperty ;
    rdfs:domain sg:EvidenceSource ;
    rdfs:range xsd:string ;
    rdfs:label "로컬 근거 경로"@ko .

sg:sourceUrl a owl:DatatypeProperty ;
    rdfs:domain sg:EvidenceSource ;
    rdfs:range xsd:anyURI ;
    rdfs:label "외부 근거 URL"@ko .

sg:sourceScope a owl:DatatypeProperty ;
    rdfs:domain sg:EvidenceSource ;
    rdfs:range xsd:string ;
    rdfs:label "근거 범위"@ko .

sg:answerLabel a owl:DatatypeProperty ;
    rdfs:domain sg:ScienceTopic ;
    rdfs:range xsd:string ;
    rdfs:label "답변 라벨"@ko ;
    rdfs:comment "[공식], [추론], [팬추론], [모순] 중 답변에 기본으로 붙일 라벨."@ko .


### =============================================
### Attractor Fields
### =============================================

sg:AF_Alpha a sg:AttractorField ;
    sg:id "AF_Alpha" ;
    sg:nameEn "Attractor Field Alpha" ;
    sg:labelKo "어트랙터 필드 알파" ;
    sg:description "SERN 디스토피아가 거시적 미래로 수속하는 세계선 묶음."@ko .

sg:AF_Beta a sg:AttractorField ;
    sg:id "AF_Beta" ;
    sg:nameEn "Attractor Field Beta" ;
    sg:labelKo "어트랙터 필드 베타" ;
    sg:description "크리스의 죽음과 제3차 세계대전 위험이 결부되는 세계선 묶음."@ko .

sg:AF_SteinsGate a sg:AttractorField ;
    sg:id "AF_SteinsGate" ;
    sg:nameEn "Steins Gate" ;
    sg:labelKo "슈타인즈 게이트" ;
    sg:description "알파와 베타의 거시적 수속 미래에서 모두 벗어나는 특수 세계선 영역."@ko .

sg:AF_Omega a sg:AttractorField ;
    sg:id "AF_Omega" ;
    sg:nameEn "Omega" ;
    sg:labelKo "오메가" ;
    sg:description "페이리스 엔딩에서 확인되는 음수 다이버전스의 특수 세계선 영역."@ko ;
    sg:note "공식 QnA에서 -0.275349%의 Ω 세계선이 명시된다."@ko .


