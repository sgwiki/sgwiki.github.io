### =============================================
### OWL-DL Axioms: Property Characteristics
### =============================================

# 인과관계 속성: 비반사적(자기 원인 불가) + 비대칭적(상호 원인 불가)
sg:causes a owl:IrreflexiveProperty, owl:AsymmetricProperty .
sg:enables a owl:IrreflexiveProperty .
sg:prevents a owl:IrreflexiveProperty, owl:AsymmetricProperty .

# 함수형 속성: Event는 정확히 하나의 EventVariation에 속한다
sg:partOfVariation a owl:FunctionalProperty .

# 함수형 속성: EventVariation은 정확히 하나의 WorldLine에 속한다
sg:belongsToWorldLine a owl:FunctionalProperty .

# 함수형 속성: WorldLine은 정확히 하나의 AttractorField에 속한다
sg:belongsToAttractorField a owl:FunctionalProperty .

# WorldLineShift 관계: 각각 함수형
sg:fromWorldLine a owl:FunctionalProperty .
sg:toWorldLine a owl:FunctionalProperty .
sg:triggeredByEvent a owl:FunctionalProperty .


### =============================================
### OWL-DL Axioms: Class Restrictions
### =============================================

sg:Event rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty sg:partOfVariation ;
      owl:cardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ;
      owl:onProperty sg:eventType ;
      owl:minCardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ;
      owl:onProperty sg:mechanismType ;
      owl:minCardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ;
      owl:onProperty sg:localDateTime ;
      owl:minCardinality "1"^^xsd:nonNegativeInteger ] .

sg:EventVariation rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty sg:belongsToWorldLine ;
      owl:cardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ;
      owl:onProperty sg:partOfMacroEvent ;
      owl:cardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ;
      owl:onProperty sg:variationIdentity ;
      owl:minCardinality "1"^^xsd:nonNegativeInteger ] .

sg:WorldLine rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty sg:belongsToAttractorField ;
      owl:cardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ;
      owl:onProperty sg:divergenceValue ;
      owl:minCardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ;
      owl:onProperty sg:isActive ;
      owl:cardinality "1"^^xsd:nonNegativeInteger ] .

sg:WorldLineShift rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty sg:fromWorldLine ;
      owl:cardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ;
      owl:onProperty sg:toWorldLine ;
      owl:cardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ;
      owl:onProperty sg:triggeredByEvent ;
      owl:cardinality "1"^^xsd:nonNegativeInteger ] ,
    [ a owl:Restriction ;
      owl:onProperty sg:shiftMoment ;
      owl:minCardinality "1"^^xsd:nonNegativeInteger ] .


### =============================================
### SWRL Rules (FOL Horn-clause 표현)
###
### 참고: pySHACL은 SWRL을 직접 실행하지 않는다.
### 동일 의미의 논리 제약은 아래 SHACL 섹션의 SPARQL Constraint로 시행된다.
### 이 선언은 OWL Reasoner(HermiT/Pellet/OWL-RL) 호환 및 문서화 목적이다.
### =============================================

### Rule 1 — 인과관계 전이 (Causal Transitivity)
### FOL: ∀E1,E2,E3 ∈ Event: causes(E1,E2) ∧ causes(E2,E3) → causes(E1,E3)

sg:Rule_CausalTransitivity a swrl:Imp ;
    swrla:isRuleEnabled "true"^^xsd:boolean ;
    rdfs:label "인과관계 전이 규칙"@ko ;
    rdfs:comment "E1이 E2의 원인이고 E2가 E3의 원인이면, E1은 E3의 원인이다."@ko ;
    swrl:body [
        a swrl:AtomList ;
        rdf:first [
            a swrl:IndividualPropertyAtom ;
            swrl:propertyPredicate sg:causes ;
            swrl:argument1 [ a swrl:Variable ; swrl:varName "e1"^^xsd:string ] ;
            swrl:argument2 [ a swrl:Variable ; swrl:varName "e2"^^xsd:string ]
        ] ;
        rdf:rest [
            a swrl:AtomList ;
            rdf:first [
                a swrl:IndividualPropertyAtom ;
                swrl:propertyPredicate sg:causes ;
                swrl:argument1 [ a swrl:Variable ; swrl:varName "e2"^^xsd:string ] ;
                swrl:argument2 [ a swrl:Variable ; swrl:varName "e3"^^xsd:string ]
            ] ;
            rdf:rest rdf:nil
        ]
    ] ;
    swrl:head [
        a swrl:AtomList ;
        rdf:first [
            a swrl:IndividualPropertyAtom ;
            swrl:propertyPredicate sg:causes ;
            swrl:argument1 [ a swrl:Variable ; swrl:varName "e1"^^xsd:string ] ;
            swrl:argument2 [ a swrl:Variable ; swrl:varName "e3"^^xsd:string ]
        ] ;
        rdf:rest rdf:nil
    ] .


### Rule 2 — enables 전이 (Enabling Transitivity)
### FOL: ∀E1,E2,E3 ∈ Event: enables(E1,E2) ∧ enables(E2,E3) → enables(E1,E3)

sg:Rule_EnablingTransitivity a swrl:Imp ;
    swrla:isRuleEnabled "true"^^xsd:boolean ;
    rdfs:label "가능화 전이 규칙"@ko ;
    rdfs:comment "E1이 E2를 가능하게 하고 E2가 E3를 가능하게 하면, E1은 E3를 가능하게 한다."@ko ;
    swrl:body [
        a swrl:AtomList ;
        rdf:first [
            a swrl:IndividualPropertyAtom ;
            swrl:propertyPredicate sg:enables ;
            swrl:argument1 [ a swrl:Variable ; swrl:varName "e1"^^xsd:string ] ;
            swrl:argument2 [ a swrl:Variable ; swrl:varName "e2"^^xsd:string ]
        ] ;
        rdf:rest [
            a swrl:AtomList ;
            rdf:first [
                a swrl:IndividualPropertyAtom ;
                swrl:propertyPredicate sg:enables ;
                swrl:argument1 [ a swrl:Variable ; swrl:varName "e2"^^xsd:string ] ;
                swrl:argument2 [ a swrl:Variable ; swrl:varName "e3"^^xsd:string ]
            ] ;
            rdf:rest rdf:nil
        ]
    ] ;
    swrl:head [
        a swrl:AtomList ;
        rdf:first [
            a swrl:IndividualPropertyAtom ;
            swrl:propertyPredicate sg:enables ;
            swrl:argument1 [ a swrl:Variable ; swrl:varName "e1"^^xsd:string ] ;
            swrl:argument2 [ a swrl:Variable ; swrl:varName "e3"^^xsd:string ]
        ] ;
        rdf:rest rdf:nil
    ] .


### Rule 3 — causes → enables 함의
### FOL: ∀E1,E2 ∈ Event: causes(E1,E2) → enables(E1,E2)

sg:Rule_CausesImpliesEnables a swrl:Imp ;
    swrla:isRuleEnabled "true"^^xsd:boolean ;
    rdfs:label "원인 → 가능화 함의 규칙"@ko ;
    rdfs:comment "E1이 E2의 원인이면 E1은 E2를 가능하게 한다."@ko ;
    swrl:body [
        a swrl:AtomList ;
        rdf:first [
            a swrl:IndividualPropertyAtom ;
            swrl:propertyPredicate sg:causes ;
            swrl:argument1 [ a swrl:Variable ; swrl:varName "e1"^^xsd:string ] ;
            swrl:argument2 [ a swrl:Variable ; swrl:varName "e2"^^xsd:string ]
        ] ;
        rdf:rest rdf:nil
    ] ;
    swrl:head [
        a swrl:AtomList ;
        rdf:first [
            a swrl:IndividualPropertyAtom ;
            swrl:propertyPredicate sg:enables ;
            swrl:argument1 [ a swrl:Variable ; swrl:varName "e1"^^xsd:string ] ;
            swrl:argument2 [ a swrl:Variable ; swrl:varName "e2"^^xsd:string ]
        ] ;
        rdf:rest rdf:nil
    ] .


### Rule 4 — WorldLineShift 출발 세계선 귀속 추론
### FOL: ∀S ∈ WorldLineShift, ∀E ∈ Event, ∀EV ∈ EventVariation, ∀WL ∈ WorldLine:
###   triggeredByEvent(S,E) ∧ partOfVariation(E,EV) ∧ belongsToWorldLine(EV,WL)
###   → fromWorldLine(S,WL)

sg:Rule_ShiftOriginWorldLine a swrl:Imp ;
    swrla:isRuleEnabled "true"^^xsd:boolean ;
    rdfs:label "세계선 이동 출발점 귀속 규칙"@ko ;
    rdfs:comment """세계선 이동을 유발한 Event가 속한 EventVariation의 WorldLine이
해당 WorldLineShift의 fromWorldLine이어야 한다."""@ko ;
    swrl:body [
        a swrl:AtomList ;
        rdf:first [
            a swrl:IndividualPropertyAtom ;
            swrl:propertyPredicate sg:triggeredByEvent ;
            swrl:argument1 [ a swrl:Variable ; swrl:varName "s"^^xsd:string ] ;
            swrl:argument2 [ a swrl:Variable ; swrl:varName "e"^^xsd:string ]
        ] ;
        rdf:rest [
            a swrl:AtomList ;
            rdf:first [
                a swrl:IndividualPropertyAtom ;
                swrl:propertyPredicate sg:partOfVariation ;
                swrl:argument1 [ a swrl:Variable ; swrl:varName "e"^^xsd:string ] ;
                swrl:argument2 [ a swrl:Variable ; swrl:varName "ev"^^xsd:string ]
            ] ;
            rdf:rest [
                a swrl:AtomList ;
                rdf:first [
                    a swrl:IndividualPropertyAtom ;
                    swrl:propertyPredicate sg:belongsToWorldLine ;
                    swrl:argument1 [ a swrl:Variable ; swrl:varName "ev"^^xsd:string ] ;
                    swrl:argument2 [ a swrl:Variable ; swrl:varName "wl"^^xsd:string ]
                ] ;
                rdf:rest rdf:nil
            ]
        ]
    ] ;
    swrl:head [
        a swrl:AtomList ;
        rdf:first [
            a swrl:IndividualPropertyAtom ;
            swrl:propertyPredicate sg:fromWorldLine ;
            swrl:argument1 [ a swrl:Variable ; swrl:varName "s"^^xsd:string ] ;
            swrl:argument2 [ a swrl:Variable ; swrl:varName "wl"^^xsd:string ]
        ] ;
        rdf:rest rdf:nil
    ] .


### Rule 5 — ConvergencePattern → EventVariation 어트랙터 필드 연결
### FOL: ∀CP ∈ ConvergencePattern, ∀EV ∈ EventVariation, ∀AF ∈ AttractorField:
###   hasVariantVariation(CP,EV) ∧ hasConvergencePattern(AF,CP) ∧ belongsToWorldLine(EV,WL)
###   → hasWorldLine(AF,WL)

sg:Rule_ConvergencePatternWorldLine a swrl:Imp ;
    swrla:isRuleEnabled "true"^^xsd:boolean ;
    rdfs:label "수속 패턴 세계선 귀속 규칙"@ko ;
    rdfs:comment """ConvergencePattern에 속한 EventVariation의 WorldLine은
해당 ConvergencePattern을 보유한 AttractorField의 WorldLine이어야 한다."""@ko ;
    swrl:body [
        a swrl:AtomList ;
        rdf:first [
            a swrl:IndividualPropertyAtom ;
            swrl:propertyPredicate sg:hasConvergencePattern ;
            swrl:argument1 [ a swrl:Variable ; swrl:varName "af"^^xsd:string ] ;
            swrl:argument2 [ a swrl:Variable ; swrl:varName "cp"^^xsd:string ]
        ] ;
        rdf:rest [
            a swrl:AtomList ;
            rdf:first [
                a swrl:IndividualPropertyAtom ;
                swrl:propertyPredicate sg:hasVariantVariation ;
                swrl:argument1 [ a swrl:Variable ; swrl:varName "cp"^^xsd:string ] ;
                swrl:argument2 [ a swrl:Variable ; swrl:varName "ev"^^xsd:string ]
            ] ;
            rdf:rest [
                a swrl:AtomList ;
                rdf:first [
                    a swrl:IndividualPropertyAtom ;
                    swrl:propertyPredicate sg:belongsToWorldLine ;
                    swrl:argument1 [ a swrl:Variable ; swrl:varName "ev"^^xsd:string ] ;
                    swrl:argument2 [ a swrl:Variable ; swrl:varName "wl"^^xsd:string ]
                ] ;
                rdf:rest rdf:nil
            ]
        ]
    ] ;
    swrl:head [
        a swrl:AtomList ;
        rdf:first [
            a swrl:IndividualPropertyAtom ;
            swrl:propertyPredicate sg:hasWorldLine ;
            swrl:argument1 [ a swrl:Variable ; swrl:varName "af"^^xsd:string ] ;
            swrl:argument2 [ a swrl:Variable ; swrl:varName "wl"^^xsd:string ]
        ] ;
        rdf:rest rdf:nil
    ] .


### =============================================
### SHACL Shapes
### =============================================

### Shape 1 — Event 구조 제약

sgsh:EventShape a sh:NodeShape ;
    sh:targetClass sg:Event ;
    rdfs:label "Event 구조 제약"@ko ;
    sh:property [
        sh:path sg:partOfVariation ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class sg:EventVariation ;
        sh:message "Event는 반드시 정확히 하나의 EventVariation에 속해야 한다."@ko
    ] ;
    sh:property [
        sh:path sg:eventType ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "actual" "intervention" "communication" "travel" "death" ) ;
        sh:message "eventType은 actual/intervention/communication/travel/death 중 하나여야 한다."@ko
    ] ;
    sh:property [
        sh:path sg:mechanismType ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "dmail" "timeleap" "physicaltravel" "videodmail" "drine" "none" ) ;
        sh:message "mechanismType은 dmail/timeleap/physicaltravel/videodmail/drine/none 중 하나여야 한다."@ko
    ] ;
    sh:property [
        sh:path sg:localDateTime ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}$" ;
        sh:message "localDateTime 형식은 YYYY-MM-DD HH:MM 이어야 한다."@ko
    ] ;
    sh:property [
        sh:path sg:timePrecision ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "exact" "approximate" "day" "unknown" ) ;
        sh:message "timePrecision은 exact/approximate/day/unknown 중 하나여야 한다."@ko
    ] .


### Shape 2 — EventVariation 세계선 논리 제약

sgsh:EventVariationShape a sh:NodeShape ;
    sh:targetClass sg:EventVariation ;
    rdfs:label "EventVariation 세계선 논리 제약"@ko ;
    sh:property [
        sh:path sg:belongsToWorldLine ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class sg:WorldLine ;
        sh:message "EventVariation은 반드시 정확히 하나의 WorldLine에 속해야 한다."@ko
    ] ;
    sh:property [
        sh:path sg:partOfMacroEvent ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class sg:MacroEvent ;
        sh:message "EventVariation은 반드시 정확히 하나의 MacroEvent에 속해야 한다."@ko
    ] ;
    sh:property [
        sh:path sg:variationIdentity ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "variationIdentity는 필수 속성이다."@ko
    ] .


### Shape 3 — WorldLine 구조 제약

sgsh:WorldLineShape a sh:NodeShape ;
    sh:targetClass sg:WorldLine ;
    rdfs:label "WorldLine 구조 제약"@ko ;
    sh:property [
        sh:path sg:belongsToAttractorField ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class sg:AttractorField ;
        sh:message "WorldLine은 반드시 정확히 하나의 AttractorField에 속해야 한다."@ko
    ] ;
    sh:property [
        sh:path sg:divergenceValue ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:message "WorldLine에는 divergenceValue가 필요하다."@ko
    ] ;
    sh:property [
        sh:path sg:isActive ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:boolean ;
        sh:message "WorldLine에는 isActive 값이 필요하다."@ko
    ] .


### Shape 4 — WorldLineShift 구조 및 논리 제약

sgsh:WorldLineShiftShape a sh:NodeShape ;
    sh:targetClass sg:WorldLineShift ;
    rdfs:label "WorldLineShift 구조 및 논리 제약"@ko ;
    sh:property [
        sh:path sg:fromWorldLine ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class sg:WorldLine ;
        sh:message "WorldLineShift는 반드시 fromWorldLine을 가져야 한다."@ko
    ] ;
    sh:property [
        sh:path sg:toWorldLine ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class sg:WorldLine ;
        sh:message "WorldLineShift는 반드시 toWorldLine을 가져야 한다."@ko
    ] ;
    sh:property [
        sh:path sg:triggeredByEvent ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class sg:Event ;
        sh:message "WorldLineShift는 반드시 triggeredByEvent를 가져야 한다."@ko
    ] ;
    sh:property [
        sh:path sg:shiftMoment ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}$" ;
        sh:message "shiftMoment 형식은 YYYY-MM-DD HH:MM 이어야 한다."@ko
    ] ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        rdfs:label "출발-도착 세계선 동일성 금지"@ko ;
        sh:message "WorldLineShift의 fromWorldLine과 toWorldLine이 동일할 수 없다."@ko ;
        sh:select """
            PREFIX sg: <http://example.org/steinsgate#>
            SELECT $this WHERE {
                $this sg:fromWorldLine ?from ;
                      sg:toWorldLine ?to .
                FILTER(?from = ?to)
            }
        """
    ] .


### Shape 5 — 인과관계 제약: 자기 causes 금지 (비반사성)

sgsh:NoSelfCausationShape a sh:NodeShape ;
    sh:targetClass sg:Event ;
    rdfs:label "자기 인과 금지"@ko ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        rdfs:label "자기 자신을 causes 하는 Event 금지"@ko ;
        sh:message "Event가 자기 자신을 원인으로 가질 수 없다 (sg:causes 비반사성)."@ko ;
        sh:select """
            PREFIX sg: <http://example.org/steinsgate#>
            SELECT $this WHERE {
                $this sg:causes $this .
            }
        """
    ] .


### Shape 6 — 인과관계 제약: causes 비대칭성 (상호 원인 금지)

sgsh:CausesAsymmetryShape a sh:NodeShape ;
    sh:targetClass sg:Event ;
    rdfs:label "인과관계 비대칭성"@ko ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        rdfs:label "상호 causes 금지"@ko ;
        sh:message "Event E1이 E2의 원인이면 E2는 E1의 원인이 될 수 없다 (sg:causes 비대칭성)."@ko ;
        sh:select """
            PREFIX sg: <http://example.org/steinsgate#>
            SELECT $this WHERE {
                $this sg:causes ?e2 .
                ?e2 sg:causes $this .
                FILTER($this != ?e2)
            }
        """
    ] .



### Shape 8 — AttractorField: 최소 하나의 WorldLine 보유

sgsh:AttractorFieldShape a sh:NodeShape ;
    sh:targetClass sg:AttractorField ;
    rdfs:label "AttractorField 구조 제약"@ko ;
    sh:property [
        sh:path sg:hasWorldLine ;
        sh:minCount 1 ;
        sh:class sg:WorldLine ;
        sh:message "AttractorField는 반드시 하나 이상의 WorldLine을 가져야 한다."@ko
    ] .


### Shape 9 — MacroEvent: 최소 하나의 EventVariation 보유

sgsh:MacroEventShape a sh:NodeShape ;
    sh:targetClass sg:MacroEvent ;
    rdfs:label "MacroEvent 구조 제약"@ko ;
    sh:property [
        sh:path sg:hasVariation ;
        sh:minCount 1 ;
        sh:class sg:EventVariation ;
        sh:message "MacroEvent는 반드시 하나 이상의 EventVariation을 가져야 한다."@ko
    ] .
# 슈타인즈게이트 온톨로지 — 위키 에피소드 정본 보강 patch (Phase 07)
# =====================================================================
# 상태: PENDING APPROVAL — 승인 + 3중 게이트(SHACL/카운트/build) 전 본체 미반영.
# 규칙: 추가만(additive). 기존 id 덮어쓰기/삭제 금지. worldlines=20 불변.
# 근거: wiki/애니메이션-에피소드/* (51화 정본) + wiki/lore/2010년-사건-연표.md
# 선행: mechanismType sh:in 에 drine 추가(01_schema/mechanism-drine.ttl) → 본 patch보다 먼저 머지.
# 머지 시: 이 파일의 트리플을 슈타인즈게이트_온톨로지.ttl 의 해당 섹션에 추가.
# 파라프레이즈: 모든 sg:summary/sg:note 텍스트는 위키 산문을 온톨로지 서술문으로 재작성.

