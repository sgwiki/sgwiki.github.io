### =============================================
### Convergence Patterns
### =============================================

sg:CP_MayuriDies_Alpha a sg:ConvergencePattern ;
    sg:id "CP_MayuriDies_Alpha" ;
    sg:labelKo "알파에서 마유리 사망 수속" ;
    sg:description "알파 어트랙터 필드에서 2010-08-13 밤 마유리의 죽음이 다양한 방식으로 반복된다."@ko ;
    sg:timeWindow "2010-08-13 night" ;
    sg:appliesToCharacter "Char_Mayuri" .

sg:CP_KurisuDies_Beta a sg:ConvergencePattern ;
    sg:id "CP_KurisuDies_Beta" ;
    sg:labelKo "베타에서 크리스 사망 수속"@ko ;
    sg:description "베타 어트랙터 필드에서 2010-07-28 크리스의 죽음이 반복된다."@ko ;
    sg:timeWindow "2010-07-28" ;
    sg:appliesToCharacter "Char_Kurisu" .

sg:CP_SERNTimeMachineCompleted_Alpha a sg:ConvergencePattern ;
    sg:id "CP_SERNTimeMachineCompleted_Alpha" ;
    sg:labelKo "알파에서 2034년 SERN 타임머신 완성 수속"@ko ;
    sg:description "알파 어트랙터 필드에서 SERN이 2034년에 타임머신을 완성하는 거시적 준비 단계."@ko ;
    sg:timeWindow "2034" .

sg:CP_SERNDystopia_Alpha a sg:ConvergencePattern ;
    sg:id "CP_SERNDystopia_Alpha" ;
    sg:labelKo "알파에서 SERN 디스토피아 수속"@ko ;
    sg:description "알파 어트랙터 필드에서 2036년 스즈하가 경험하는 완성형 SERN 디스토피아 미래."@ko ;
    sg:note "2034년 타임머신 완성과 2036년 완성형 디스토피아를 분리해 기록한다."@ko ;
    sg:timeWindow "2036" .

sg:CP_WW3_Beta a sg:ConvergencePattern ;
    sg:id "CP_WW3_Beta" ;
    sg:labelKo "베타에서 제3차 세계대전 수속"@ko ;
    sg:description "베타 어트랙터 필드에서 나카바치 논문 유출로 발생하는 전쟁 수속 패턴."@ko ;
    sg:timeWindow "2025" .

sg:AF_Alpha sg:hasConvergencePattern
    sg:CP_MayuriDies_Alpha,
    sg:CP_SERNTimeMachineCompleted_Alpha,
    sg:CP_SERNDystopia_Alpha .

sg:AF_Beta sg:hasConvergencePattern
    sg:CP_KurisuDies_Beta,
    sg:CP_WW3_Beta .


