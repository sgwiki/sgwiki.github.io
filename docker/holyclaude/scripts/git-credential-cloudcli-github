#!/bin/sh
set -eu

operation="${1:-}"
[ "$operation" = "get" ] || exit 0

protocol=""
host=""

while IFS='=' read -r key value; do
    [ -n "$key" ] || break
    case "$key" in
        protocol) protocol="$value" ;;
        host) host="$value" ;;
    esac
done

[ "$protocol" = "https" ] || exit 0
[ "$host" = "github.com" ] || exit 0

db="${CLOUDCLI_AUTH_DB:-$HOME/.cloudcli/auth.db}"
[ -r "$db" ] || exit 0
command -v sqlite3 >/dev/null 2>&1 || exit 0

token="$(
    sqlite3 "$db" "
        select credential_value
        from user_credentials
        where credential_type = 'github_token'
          and is_active = 1
          and length(credential_value) > 0
        order by id desc
        limit 1;
    " 2>/dev/null || true
)"

[ -n "$token" ] || exit 0

printf 'username=x-access-token\n'
printf 'password=%s\n' "$token"
